<!DOCTYPE html><html><head><meta name="viewport" content="width=device-width,initial-scale=1"><title>Joki Admin</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0e1a;--surface:#111827;--s2:#1a2036;--border:#1e2d4a;--accent:#38bdf8;--yellow:#f59e0b;--green:#10b981;--red:#ef4444;--text:#d4e3ff;--muted:#6b82aa}
[data-theme="light"]{--bg:#f0f4fa;--surface:#fff;--s2:#e8edf5;--border:#c8d5e8;--text:#1a2744;--muted:#6b7fa0}
*{box-sizing:border-box;margin:0;padding:0}body{background:var(--bg);color:var(--text);font-family:'Nunito',sans-serif;min-height:100vh;padding-bottom:60px}
.pin-s{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:20px}.pin-b{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:36px 28px;width:100%;max-width:300px;text-align:center}
.pin-t{font-size:1.2rem;font-weight:700;margin-bottom:6px}.pin-sub{font-size:.8rem;color:var(--muted);margin-bottom:20px}
.pin-i{width:100%;padding:12px;border:2px solid var(--border);border-radius:11px;background:var(--s2);color:var(--text);font-family:'DM Mono',monospace;font-size:1.1rem;text-align:center;letter-spacing:.5em}.pin-i:focus{outline:0;border-color:var(--accent)}
.pin-go{width:100%;padding:12px;margin-top:14px;background:var(--accent);color:#fff;border:none;border-radius:11px;font-weight:700;cursor:pointer}.pin-e{color:var(--red);font-size:.8rem;margin-top:10px;display:none}
#app{display:none}.header{background:linear-gradient(175deg,#0f172a 0%,#1e3a5f 25%,#2563eb 50%,#38bdf8 75%,#5eead4 100%);padding:24px 16px 20px;text-align:center;position:relative;overflow:hidden}.header .stars{position:absolute;inset:0;pointer-events:none}.header .star{position:absolute;width:2px;height:2px;background:#fff;border-radius:50%;opacity:.4}
.stats{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;position:relative;z-index:1}.stat{background:var(--s2);border-radius:8px;padding:7px;text-align:center}.stat-v{font-size:.95rem;font-weight:800}.stat-l{font-size:.55rem;color:var(--muted);text-transform:uppercase}
.search-row{display:flex;gap:6px;margin-top:8px;position:relative;z-index:1}.search-i{flex:1;padding:8px 12px;background:var(--s2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'DM Mono',monospace;font-size:.82rem}.search-i:focus{outline:0;border-color:var(--accent)}
.sys-btn{padding:8px 16px;background:var(--accent);color:#fff;border:none;border-radius:8px;font-weight:700;cursor:pointer;font-size:.8rem}
.tabs{display:flex;gap:4px;margin:10px 16px 0;overflow-x:auto}.tab{padding:8px 14px;border-radius:8px;font-size:.72rem;font-weight:700;cursor:pointer;color:var(--muted);background:var(--surface);border:1px solid var(--border);white-space:nowrap}.tab.active{background:var(--accent);color:#fff;border-color:var(--accent)}
.panel{display:none;padding:10px 16px}.panel.active{display:block}
.oc{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:12px;margin-bottom:8px}
.rec-id{font-family:'DM Mono',monospace;font-size:.78rem;font-weight:700;color:var(--accent)}
.cg{display:grid;grid-template-columns:1fr 1fr;gap:4px 12px;margin:6px 0}.cl{font-size:.58rem;color:var(--muted);text-transform:uppercase}.cv{font-size:.78rem;font-weight:600}
.sp{font-size:.62rem;font-weight:700;padding:3px 8px;border-radius:6px;text-transform:uppercase}.st-u{background:rgba(245,158,11,.1);color:var(--yellow)}.st-r{background:rgba(56,189,248,.1);color:var(--accent)}.st-c{background:rgba(16,185,129,.1);color:var(--green)}.st-x{background:rgba(239,68,68,.1);color:var(--red)}
.btn{padding:8px 14px;border:none;border-radius:8px;font-size:.72rem;font-weight:700;cursor:pointer;margin-right:4px;margin-top:4px}.btn-g{background:var(--green);color:#fff}.btn-r{background:var(--red);color:#fff}.btn-b{background:var(--accent);color:#fff}
.empty{text-align:center;padding:30px;color:var(--muted);font-size:.82rem}
.fin-row{display:flex;gap:6px;align-items:center;flex-wrap:wrap;margin-bottom:8px}.fin-sel{padding:8px;background:var(--s2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:.8rem}.fin-input{padding:8px;background:var(--s2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'DM Mono',monospace;font-size:.82rem;width:100px}
.toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);padding:10px 20px;border-radius:10px;font-size:.82rem;font-weight:700;opacity:0;transition:.3s;z-index:999;pointer-events:none}.toast.show{opacity:1}.toast.ok{background:var(--green);color:#fff}.toast.er{background:var(--red);color:#fff}
.th-btn{padding:5px 12px;border-radius:7px;font-size:.7rem;font-weight:700;cursor:pointer;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.2);color:#fff}
</style></head><body>
<div class="pin-s" id="pinS"><div class="pin-b"><div class="pin-t">🔒 Joki Admin</div><div class="pin-sub">Enter PIN</div><input type="password" class="pin-i" id="pinI" maxlength="8" placeholder="------" onkeydown="if(event.key==='Enter')chkPin()"><button class="pin-go" onclick="chkPin()">Enter</button><div class="pin-e" id="pinE"></div></div></div>
<div id="app"><div class="header"><div class="stars" id="hSt"></div><div style="position:relative;z-index:1"><div style="display:flex;justify-content:flex-end;margin-bottom:10px"><button class="th-btn" id="thBtn" onclick="tgTh()">Light</button></div><div style="display:flex;flex-direction:column;align-items:center;gap:6px"><img src="https://lh3.googleusercontent.com/d/1HmBuyY8D5ccBUUAP-GsCuiTNxpxsaDsu" style="width:52px;height:52px;border-radius:14px;object-fit:cover;border:2px solid rgba(255,255,255,.2)"><div style="font-size:1.1rem;font-weight:800;color:#fff">Admin · Joki</div></div></div><div style="height:12px"></div>
<div class="stats"><div class="stat"><div class="stat-v" id="stU">-</div><div class="stat-l">Unpaid</div></div><div class="stat"><div class="stat-v" id="stA">-</div><div class="stat-l">Active</div></div><div class="stat"><div class="stat-v" id="stC">-</div><div class="stat-l">Done</div></div></div>
<div style="display:flex;gap:8px;padding:8px 0;font-size:.7rem;font-weight:600;position:relative;z-index:1;justify-content:center" id="wSt"></div>
<div class="search-row"><input class="search-i" id="sI" placeholder="Search name/ID" onkeydown="if(event.key==='Enter')doSearch()"><button class="sys-btn" onclick="doSearch()">Search</button></div></div>
<div class="tabs"><div class="tab active" data-tab="unpaid" onclick="sTab('unpaid')">Unpaid</div><div class="tab" data-tab="active" onclick="sTab('active')">Active</div><div class="tab" data-tab="all" onclick="sTab('all')">All</div><div class="tab" data-tab="revenue" onclick="sTab('revenue')">Revenue</div><div class="tab" data-tab="finance" onclick="sTab('finance')">Finance</div><div class="tab" data-tab="workers" onclick="sTab('workers')">Workers</div><div class="tab" data-tab="refunds" onclick="sTab('refunds')">Refunds</div><div class="tab" data-tab="errors" onclick="sTab('errors')">Errors</div></div>
<div class="panel active" id="p-unpaid"><div id="lU"></div></div>
<div class="panel" id="p-active"><div id="lA"></div></div>
<div class="panel" id="p-all"><div id="lAll"></div></div>
<div class="panel" id="p-revenue"><div id="revC"><div class="empty">Loading...</div></div></div>
<div class="panel" id="p-finance"><div style="font-size:.85rem;font-weight:700;margin-bottom:8px">Add Bonus / Deduction</div><div class="fin-row"><select class="fin-sel" id="finW"></select><select class="fin-sel" id="finT"><option>Bonus</option><option>Deduction</option></select><input class="fin-input" id="finA" type="number" placeholder="Amount"><input class="fin-input" id="finN" placeholder="Notes" style="width:140px"><button class="btn btn-g" onclick="addFin()">Add</button></div><div style="margin-top:12px;font-size:.85rem;font-weight:700;margin-bottom:8px">📋 History</div><div id="finH"></div><div style="margin-top:12px;font-size:.85rem;font-weight:700;margin-bottom:8px">🚫 Blacklist</div><div id="blList"></div><div class="fin-row" style="margin-top:6px"><input class="fin-input" id="blAdd" placeholder="Contact" style="width:160px"><button class="btn btn-r" onclick="addBL()">Block</button></div>
<div style="margin-top:16px;padding:12px;background:var(--s2);border-radius:10px"><div style="font-size:.85rem;font-weight:700;margin-bottom:8px">Change Admin PIN</div><div class="fin-row"><input type="password" class="fin-input" id="aOP" placeholder="Current" maxlength="8" style="max-width:120px"><input type="password" class="fin-input" id="aNP" placeholder="New (6+)" maxlength="8" style="max-width:120px"><button class="btn btn-g" onclick="chgAP()">Change</button></div></div></div>
<div class="panel" id="p-workers"><div id="wL"></div></div>
<div class="panel" id="p-refunds"><div id="rfL"><div class="empty">Loading...</div></div></div>
<div class="panel" id="p-errors"><div id="eL"></div></div></div>
<div class="toast" id="toast"></div>
<script>
var _isDark=true;
(function(){var c=document.getElementById('hSt');for(var i=0;i<40;i++){var d=document.createElement('div');d.className='star';d.style.left=Math.random()*100+'%';d.style.top=Math.random()*100+'%';d.style.width=d.style.height=(1+Math.random()*1.5)+'px';d.style.opacity=(.15+Math.random()*.4);c.appendChild(d)}})();
function tgTh(){_isDark=!_isDark;document.documentElement.setAttribute('data-theme',_isDark?'':'light');document.getElementById('thBtn').textContent=_isDark?'Light':'Dark'}
function esc(s){if(!s)return'';var d=document.createElement('div');d.textContent=String(s);return d.innerHTML}
function fmtIDR(n){return'Rp '+Number(n).toLocaleString('id-ID')}
function toast(m,t){var e=document.getElementById('toast');e.textContent=m;e.className='toast '+(t||'ok');e.classList.add('show');setTimeout(function(){e.classList.remove('show')},3500)}
function chkPin(){google.script.run.withSuccessHandler(function(r){if(r.success){document.getElementById('pinS').style.display='none';document.getElementById('app').style.display='block';load()}else{document.getElementById('pinE').textContent=r.message||'Incorrect';document.getElementById('pinE').style.display='block'}}).withFailureHandler(function(e){document.getElementById('pinE').textContent=e.message;document.getElementById('pinE').style.display='block'}).verifyAdminAccess(document.getElementById('pinI').value)}
function sTab(n){document.querySelectorAll('.tab').forEach(function(t){t.classList.toggle('active',t.dataset.tab===n)});document.querySelectorAll('.panel').forEach(function(p){p.classList.toggle('active',p.id==='p-'+n)});if(n==='revenue')loadRev();if(n==='refunds')loadRefunds();if(n==='errors')loadErr();if(n==='finance'){loadFinH();loadBL();}if(n==='workers')loadW();if(n==='unpaid'||n==='active'||n==='all')loadOrders(n)}
function stPill(s){var c='st-x';if(s==='Waiting Payment')c='st-u';else if(s==='Running'||s==='Pending')c='st-r';else if(s==='Completed')c='st-c';return'<span class="sp '+c+'">'+esc(s)+'</span>'}
function renderCard(o,btns){var nm=String(o.notes||''),pm=nm.match(/Pay:(\w+)/),payM=pm?pm[1]:'—',p=payM==='PayPal'&&o.priceUSD?'$'+Number(o.priceUSD).toFixed(2):o.priceIDR?fmtIDR(o.priceIDR):'—';
return'<div class="oc"><div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px"><div><div style="font-size:.92rem;font-weight:800">'+esc(o.customer)+'</div><div style="font-family:DM Mono,monospace;font-size:.68rem;color:var(--accent)">'+esc(o.record)+'</div></div>'+stPill(o.status)+'</div><div style="display:flex;justify-content:space-between;font-size:.78rem;padding:6px 0;border-top:1px solid var(--border);margin-top:6px"><span style="font-weight:700">'+esc(o.product)+'</span><span style="color:var(--yellow);font-weight:700">'+p+'</span></div><div style="font-size:.72rem;color:var(--muted)">'+esc(o.loginMethod)+(o.worker?' · '+esc(o.worker):'')+(o.contact?' · '+esc(o.contact):'')+'</div>'+(btns||'')+'</div>'}
function loadOrders(f){var q=document.getElementById('sI').value.trim();google.script.run.withSuccessHandler(function(orders){var id=f==='unpaid'?'lU':f==='active'?'lA':'lAll';if(!orders.length){document.getElementById(id).innerHTML='<div class="empty">No orders</div>';return}document.getElementById(id).innerHTML=orders.map(function(o){var b='';if(f==='unpaid'&&o.status==='Waiting Payment')b='<button class="btn btn-g" onclick="mPaid(\''+esc(o.record)+'\')">✓ Paid</button><button class="btn btn-g" onclick="bPaid(\''+esc(o.contact)+'\')">All ('+esc(o.customer)+')</button><button class="btn btn-r" onclick="mCancel(\''+esc(o.record)+'\')">✕</button>';if(f==='active'&&(o.status==='Running'||o.status==='Pending')){b='<select class="fin-sel" id="rw_'+esc(o.record)+'">'+_wOpts+'</select><button class="btn btn-b" onclick="mReassign(\''+esc(o.record)+'\')">Reassign</button>';if(o.payment==='Paid'&&o.complaint!=='REFUND')b+='<button class="btn btn-r" onclick="mRefund(\''+esc(o.record)+'\')">Refund</button>'}return renderCard(o,b)}).join('')}).withFailureHandler(function(e){toast(e.message,'er')}).getAdminOrders(f,q)}
function doSearch(){var a=document.querySelector('.tab.active');loadOrders(a?a.dataset.tab:'unpaid')}
function mPaid(r){google.script.run.withSuccessHandler(function(r2){toast(r2.message,r2.success?'ok':'er');load()}).withFailureHandler(function(e){toast(e.message,'er')}).markOrderPaid(r)}
function bPaid(ct){if(!confirm('Mark ALL unpaid from this buyer?'))return;google.script.run.withSuccessHandler(function(r){toast(r.message,r.success?'ok':'er');load()}).withFailureHandler(function(e){toast(e.message,'er')}).markAllPaidByContact(ct)}
function mCancel(r){if(!confirm('Cancel?'))return;google.script.run.withSuccessHandler(function(r2){toast(r2.message,r2.success?'ok':'er');load()}).withFailureHandler(function(e){toast(e.message,'er')}).cancelOrder(r)}
function mReassign(r){var s=document.getElementById('rw_'+r);if(!s)return;google.script.run.withSuccessHandler(function(r2){toast(r2.message,r2.success?'ok':'er');load()}).withFailureHandler(function(e){toast(e.message,'er')}).reassignWorker(r,s.value)}
function mRefund(r){if(!confirm('Force refund '+r+'?'))return;google.script.run.withSuccessHandler(function(r2){toast(r2.message,r2.success?'ok':'er');load()}).withFailureHandler(function(e){toast(e.message,'er')}).adminForceRefund(r)}
function loadRev(){google.script.run.withSuccessHandler(function(rv){var h='<div style="background:var(--s2);border:1px solid var(--border);border-radius:12px;padding:16px;margin-bottom:12px;text-align:center"><div style="font-size:.65rem;color:var(--muted);text-transform:uppercase">'+esc(rv.monthName)+'</div><div style="font-size:1.3rem;font-weight:800;color:var(--green)">'+esc(rv.monthTotalF)+'</div><div style="font-size:.78rem;color:var(--muted)">'+rv.monthCount+' paid</div><div style="display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:10px"><div style="background:var(--surface);border-radius:8px;padding:8px;text-align:center"><div style="font-size:.6rem;color:var(--muted);text-transform:uppercase">Worker Cost</div><div style="font-size:.82rem;font-weight:800;color:var(--red)">-'+esc(rv.payrollCostF)+'</div></div><div style="background:var(--surface);border-radius:8px;padding:8px;text-align:center"><div style="font-size:.6rem;color:var(--muted);text-transform:uppercase">Paid Out</div><div style="font-size:.82rem;font-weight:800;color:var(--yellow)">'+esc(rv.paidOutF)+'</div></div><div style="background:var(--surface);border-radius:8px;padding:8px;text-align:center"><div style="font-size:.6rem;color:var(--muted);text-transform:uppercase">Unpaid</div><div style="font-size:.82rem;font-weight:800;color:'+(rv.unpaidBal>0?'var(--yellow)':'var(--green)')+'">'+esc(rv.unpaidBalF)+'</div></div><div style="background:var(--surface);border-radius:8px;padding:8px;text-align:center"><div style="font-size:.6rem;color:var(--muted);text-transform:uppercase">Net Profit</div><div style="font-size:.82rem;font-weight:800;color:'+(rv.netProfit>=0?'var(--green)':'var(--red)')+'">'+esc(rv.netProfitF)+'</div></div></div></div>';if(rv.days&&rv.days.length)rv.days.forEach(function(d,idx){h+='<div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;margin-bottom:6px;overflow:hidden"><div style="display:flex;justify-content:space-between;align-items:center;padding:10px 12px;cursor:pointer" onclick="var el=document.getElementById(\'rv'+idx+'\');el.style.display=el.style.display===\'none\'?\'block\':\'none\'"><div><div style="font-weight:700;font-size:.82rem">'+esc(d.display)+'</div><div style="font-size:.65rem;color:var(--muted)">'+d.count+' order(s)</div></div><div style="font-family:DM Mono,monospace;font-weight:700;color:var(--green);font-size:.85rem">'+fmtIDR(d.idr)+'</div></div><div id="rv'+idx+'" style="display:none;border-top:1px solid var(--border);padding:6px 12px">'+(d.orders?d.orders.map(function(o){return'<div style="display:flex;justify-content:space-between;padding:4px 0;font-size:.74rem"><span style="font-weight:700">'+esc(o.customer)+'</span><span style="font-family:DM Mono,monospace;color:var(--green);font-weight:600">'+fmtIDR(o.idr)+'</span></div>'}).join(''):'')+'</div></div>'});else h+='<div class="empty">No data</div>';if(rv.leaderboard&&rv.leaderboard.length){h+='<div style="margin-top:16px;font-size:.85rem;font-weight:700;margin-bottom:8px">🏆 Worker Performance ('+esc(rv.monthName)+')</div>';rv.leaderboard.forEach(function(w,i){var medal=i===0?'🥇':i===1?'🥈':'🥉';var stars=w.avgRating>0?'⭐'+w.avgRating+' ('+w.ratingCount+')':'No ratings';h+='<div style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px;margin-bottom:6px"><div style="display:flex;justify-content:space-between;align-items:center"><span style="font-size:.95rem;font-weight:800">'+medal+' '+esc(w.name)+'</span><span style="font-size:.7rem;color:var(--yellow)">'+stars+'</span></div><div style="margin-top:6px;font-size:.78rem;color:var(--muted)">'+w.orderCount+' orders completed</div></div>'})}document.getElementById('revC').innerHTML=h}).withFailureHandler(function(){document.getElementById('revC').innerHTML='<div class="empty">Error</div>'}).getRevenueData()}
function loadW(){google.script.run.withSuccessHandler(function(s){var workers=s.workers||[];document.getElementById('wL').innerHTML=workers.map(function(w){var clr=w.status==='Open'?'var(--green)':'var(--red)';return'<div class="oc"><div style="display:flex;justify-content:space-between;align-items:center"><div style="font-weight:700;font-size:.88rem">'+esc(w.name)+'</div><span style="color:'+clr+';font-weight:700;font-size:.78rem">'+esc(w.status)+'</span></div><div style="margin-top:8px"><button class="btn btn-g" onclick="setWS(\''+esc(w.name)+'\',\'Open\')">Open</button><button class="btn btn-r" onclick="setWS(\''+esc(w.name)+'\',\'Close\')">Close</button></div></div>'}).join('')}).withFailureHandler(function(){}).getAdminStats()}
function setWS(name,status){google.script.run.withSuccessHandler(function(r){toast(r.message,r.success?'ok':'er');load();loadW()}).withFailureHandler(function(e){toast(e.message,'er')}).setWorkerStatus(name,status)}
function loadErr(){google.script.run.withSuccessHandler(function(errs){var el=document.getElementById('eL');if(!errs.length){el.innerHTML='<div class="empty">No errors</div>';return}el.innerHTML=errs.map(function(e){return'<div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:6px;font-size:.75rem"><div style="font-size:.62rem;color:var(--muted)">'+esc(e.time)+'</div><div style="font-weight:700;color:var(--red)">'+esc(e.fn)+'</div><div>'+esc(e.error)+'</div></div>'}).join('')}).withFailureHandler(function(){}).getErrorLogs()}
function addFin(){var w=document.getElementById('finW').value,t=document.getElementById('finT').value,a=document.getElementById('finA').value,n=document.getElementById('finN').value;if(t==='Deduction')a=-Math.abs(Number(a));google.script.run.withSuccessHandler(function(r){toast(r.message,r.success?'ok':'er');document.getElementById('finA').value='';document.getElementById('finN').value='';if(r.success)loadFinH()}).withFailureHandler(function(e){toast(e.message,'er')}).addFinanceEntry(w,t,a,n)}
function loadFinH(){google.script.run.withSuccessHandler(function(entries){var el=document.getElementById('finH');if(!entries||!entries.length){el.innerHTML='<div class="empty">No entries</div>';return}el.innerHTML=entries.map(function(e){var clr=e.amount>0?'var(--green)':'var(--red)';var icon=e.amount>0?'💰':'💸';return'<div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:5px;display:flex;justify-content:space-between;align-items:center"><div><div style="font-size:.78rem;font-weight:700">'+icon+' '+esc(e.worker)+' — '+esc(e.type)+'</div>'+(e.notes?'<div style="font-size:.68rem;color:var(--muted);margin-top:2px">'+esc(e.notes)+'</div>':'')+'<div style="font-size:.62rem;color:var(--muted);margin-top:2px">'+esc(e.date)+'</div></div><div style="font-family:DM Mono,monospace;font-weight:700;color:'+clr+';font-size:.82rem">'+(e.amount>0?'+':'-')+e.amountF+'</div></div>'}).join('')}).withFailureHandler(function(){}).getFinanceHistory()}
function chgAP(){google.script.run.withSuccessHandler(function(r){toast(r.message,r.success?'ok':'er')}).withFailureHandler(function(e){toast(e.message,'er')}).changeAdminPin(document.getElementById('aOP').value,document.getElementById('aNP').value)}
function load(){google.script.run.withSuccessHandler(function(s){_wOpts=(s.workers||[]).map(function(w){return'<option>'+w.name+'</option>'}).join('');var fw=document.getElementById('finW');if(fw)fw.innerHTML=_wOpts;document.getElementById('stU').textContent=s.unpaid;document.getElementById('stA').textContent=s.active;document.getElementById('stC').textContent=s.completed;var wh='';(s.workers||[]).forEach(function(w){var isO=w.status==='Open';wh+='<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:6px;font-size:.68rem;font-weight:700;background:'+(isO?'rgba(16,185,129,.15)':'rgba(239,68,68,.15)')+';color:'+(isO?'#5eead4':'#fca5a5')+'">'+esc(w.name)+' <span style="font-size:.55rem">'+esc(w.status)+'</span></span> '});document.getElementById('wSt').innerHTML=wh}).withFailureHandler(function(){}).getAdminStats();var a=document.querySelector('.tab.active');var cur=a?a.dataset.tab:'unpaid';if(cur==='unpaid'||cur==='active'||cur==='all')loadOrders(cur);else loadOrders('unpaid')}
function loadRefunds(){google.script.run.withSuccessHandler(function(refs){var el=document.getElementById('rfL');if(!refs||!refs.length){el.innerHTML='<div class="empty">No refund requests</div>';return}el.innerHTML=refs.map(function(r){return'<div class="oc"><div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px"><div><div style="font-size:.92rem;font-weight:800">'+esc(r.customer)+'</div><div style="font-family:DM Mono,monospace;font-size:.68rem;color:var(--accent)">'+esc(r.record)+'</div></div><span style="font-size:.68rem;color:var(--yellow);font-weight:700">PENDING</span></div><div style="font-size:.78rem;padding:4px 0">'+esc(r.product)+' · '+(r.paymentMethod==='PayPal'?'$'+Number(r.priceUSD).toFixed(2):fmtIDR(r.priceIDR))+'</div><div style="font-size:.72rem;color:var(--muted)">Reason: '+esc(r.reason)+'</div>'+(r.bankName?'<div style="font-size:.72rem;color:var(--muted)">Bank: '+esc(r.bankName)+' · '+esc(r.bankAccount)+'</div>':'')+'<div style="margin-top:6px"><button class="btn btn-g" onclick="appRef(\''+esc(r.record)+'\')">✅ Approve</button><button class="btn btn-r" onclick="rejRef(\''+esc(r.record)+'\')">❌ Reject</button></div></div>'}).join('')}).withFailureHandler(function(){document.getElementById('rfL').innerHTML='<div class="empty">Error</div>'}).getRefundRequests()}
function appRef(r){if(!confirm('Approve refund '+r+'?'))return;google.script.run.withSuccessHandler(function(r2){toast(r2.message,r2.success?'ok':'er');loadRefunds();load()}).withFailureHandler(function(e){toast(e.message,'er')}).approveRefund(r)}
function rejRef(r){if(!confirm('Reject refund '+r+'?'))return;google.script.run.withSuccessHandler(function(r2){toast(r2.message,r2.success?'ok':'er');loadRefunds()}).withFailureHandler(function(e){toast(e.message,'er')}).rejectRefund(r)}
function addBL(){var v=document.getElementById('blAdd').value.trim();if(!v)return;google.script.run.withSuccessHandler(function(r){toast(r.message,r.success?'ok':'er');document.getElementById('blAdd').value='';loadBL()}).withFailureHandler(function(e){toast(e.message,'er')}).addBlacklist(v)}
function rmBL(v){google.script.run.withSuccessHandler(function(r){toast(r.message,r.success?'ok':'er');loadBL()}).withFailureHandler(function(e){toast(e.message,'er')}).removeBlacklist(v)}
function loadBL(){google.script.run.withSuccessHandler(function(list){var el=document.getElementById('blList');el.innerHTML=list.length?list.map(function(b){return'<div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:8px 12px;margin-bottom:4px;display:flex;justify-content:space-between;align-items:center;font-size:.78rem"><span>'+esc(b)+'</span><button class="btn btn-r" style="margin:0;padding:4px 10px;font-size:.68rem" onclick="rmBL(\''+esc(b)+'\')">✕</button></div>'}).join(''):'<div class="empty" style="padding:10px">No blocked contacts</div>'}).withFailureHandler(function(){}).getBlacklist()}
setInterval(load,15000);
</script></body></html>
 
