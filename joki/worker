<!DOCTYPE html><html><head><meta name="viewport" content="width=device-width,initial-scale=1"><title>Worker — <?= workerName ?></title>
<link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
:root{--bg:#060a18;--surface:#0c1229;--s2:#111a3a;--border:#1a2d5a;--accent:#38bdf8;--green:#10b981;--yellow:#f59e0b;--red:#ef4444;--text:#e2e8f0;--muted:#7b93bd}
[data-theme="light"]{--bg:#f0f4fa;--surface:#fff;--s2:#e8edf5;--border:#c8d5e8;--text:#1a2744;--muted:#6b7fa0}
*{box-sizing:border-box;margin:0;padding:0}body{background:var(--bg);color:var(--text);font-family:'Nunito',sans-serif;font-weight:500;min-height:100vh;padding-bottom:60px}
.pin-s{display:flex;align-items:center;justify-content:center;min-height:100vh;padding:20px}.pin-b{background:var(--surface);border:1px solid var(--border);border-radius:20px;padding:36px 28px;width:100%;max-width:300px;text-align:center}
.pin-t{font-size:1.2rem;font-weight:700;margin-bottom:6px}.pin-sub{font-size:.8rem;color:var(--muted);margin-bottom:20px}
.pin-i{width:100%;padding:12px;border:2px solid var(--border);border-radius:11px;background:var(--s2);color:var(--text);font-family:'DM Mono',monospace;font-size:1.1rem;text-align:center;letter-spacing:.5em}.pin-i:focus{outline:0;border-color:var(--accent)}
.pin-go{width:100%;padding:12px;margin-top:14px;background:var(--accent);color:#fff;border:none;border-radius:11px;font-weight:700;cursor:pointer}.pin-e{color:var(--red);font-size:.8rem;margin-top:10px;display:none}
.hdr{background:linear-gradient(175deg,#0f172a 0%,#1e3a5f 25%,#2563eb 50%,#38bdf8 75%,#5eead4 100%);padding:24px 20px 20px;text-align:center;position:relative;overflow:hidden}.hdr .stars{position:absolute;inset:0;pointer-events:none}.hdr .star{position:absolute;width:2px;height:2px;background:#fff;border-radius:50%;opacity:.4}
.on-pill{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;border-radius:99px;font-size:.62rem;font-weight:700;color:var(--green);background:rgba(16,185,129,.08)}.pulse{width:6px;height:6px;border-radius:50%;background:var(--green);animation:pu 2s infinite}@keyframes pu{0%,100%{opacity:1}50%{opacity:.3}}
.tabs-s{overflow-x:auto;padding:0 14px;border-bottom:1px solid var(--border)}.tabs{display:flex;min-width:max-content}.tab{padding:10px 12px;font-size:.72rem;font-weight:700;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;position:relative}.tab.on{color:var(--accent);border-bottom-color:var(--accent)}.tab-badge{position:absolute;top:4px;right:2px;background:var(--red);color:#fff;font-size:.5rem;min-width:14px;height:14px;border-radius:7px;display:flex;align-items:center;justify-content:center;font-weight:700}
.pnl{display:none;padding:12px 14px}.pnl.on{display:block}
.oc{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:12px;margin-bottom:10px}
.rec{font-family:'DM Mono',monospace;font-size:.78rem;font-weight:700;color:var(--accent)}.cust{font-size:.68rem;color:var(--muted);margin-top:1px}
.inf{display:flex;justify-content:space-between;font-size:.78rem;padding:3px 0}.inf-l{color:var(--muted)}.inf-v{font-weight:700}
.btn{padding:8px 14px;border:none;border-radius:8px;font-size:.75rem;font-weight:700;cursor:pointer;width:100%;margin-top:5px}.btn:active{transform:scale(.97)}.btn:disabled{opacity:.3}
.btn-p{background:var(--accent);color:#fff}.btn-g{background:var(--green);color:#fff}.btn-y{background:var(--yellow);color:#1a1a1a;width:auto}.btn-r{background:rgba(239,68,68,.1);color:var(--red);border:1px solid rgba(239,68,68,.15)}
.cred-box{background:var(--s2);border:1px solid var(--border);border-radius:8px;padding:8px 10px;margin:6px 0;font-size:.72rem;font-family:'DM Mono',monospace;word-break:break-all}
.proof-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(65px,1fr));gap:6px;margin-top:6px}.proof-item{position:relative}.proof-thumb{width:100%;aspect-ratio:1;object-fit:cover;border-radius:6px;border:1px solid var(--border);cursor:pointer}.proof-del{position:absolute;top:-4px;right:-4px;width:18px;height:18px;border-radius:50%;background:var(--red);color:#fff;border:none;font-size:10px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.upload-area{border:2px dashed var(--border);border-radius:10px;padding:14px;text-align:center;cursor:pointer;margin-top:8px;transition:.15s;background:var(--s2)}.upload-area:hover{border-color:var(--accent);color:var(--accent)}.upload-area:hover{border-color:var(--accent)}
.search-box{position:relative;margin-bottom:10px;z-index:1}.search-box input{width:100%;font-family:'DM Mono',monospace;padding:9px 12px 9px 34px;background:var(--s2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-size:.82rem}.search-box input:focus{outline:0;border-color:var(--accent)}.search-box::before{content:'🔍';position:absolute;left:10px;top:50%;transform:translateY(-50%);font-size:.8rem}
.sort-row{display:flex;gap:6px;margin-bottom:8px}.sort-btn{padding:5px 10px;border-radius:16px;font-size:.68rem;font-weight:600;border:1px solid var(--border);background:var(--surface);color:var(--muted);cursor:pointer}.sort-btn.on{border-color:var(--accent);color:var(--accent);background:rgba(56,189,248,.08)}
.pr-c{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px;margin-bottom:8px}.pr-m{font-size:.88rem;font-weight:800;color:var(--accent);margin-bottom:6px}.pr-row{display:flex;justify-content:space-between;font-size:.78rem;padding:3px 0}
.set-c{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px;margin-bottom:10px}.set-r{display:flex;gap:6px;margin-top:8px}.set-i{flex:1;padding:8px;border:1px solid var(--border);border-radius:7px;background:var(--s2);color:var(--text);font-family:'DM Mono',monospace;font-size:.82rem;text-align:center}.set-b{padding:8px 16px;border:none;border-radius:7px;background:var(--accent);color:#fff;font-weight:700;font-size:.78rem;cursor:pointer}
.rv-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:12px;margin-bottom:8px}
.modal{display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:999;align-items:center;justify-content:center;cursor:pointer}.modal.on{display:flex}.modal img{max-width:95%;max-height:90vh;border-radius:8px}
.toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);padding:10px 20px;border-radius:10px;font-size:.82rem;font-weight:700;opacity:0;transition:.3s;z-index:101;pointer-events:none}.toast.show{opacity:1}.toast.ok{background:var(--green);color:#fff}.toast.er{background:var(--red);color:#fff}
.empty{text-align:center;padding:20px;color:var(--muted);font-size:.82rem}
input,textarea,select{background:var(--s2)!important;color:var(--text)!important;border-color:var(--border)!important}input:focus,textarea:focus,select:focus{border-color:var(--accent)!important;outline:0}input[type=number]{-moz-appearance:textfield}input::-webkit-outer-spin-button,input::-webkit-inner-spin-button{-webkit-appearance:none}
.notif-b{display:none;background:rgba(245,158,11,.1);border:1px solid rgba(245,158,11,.2);padding:8px;text-align:center;font-size:.78rem;font-weight:700;color:var(--yellow)}.notif-b.show{display:block}
</style></head><body>
<div class="pin-s" id="pinS"><div class="pin-b"><div class="pin-t">👋 <?= workerName ?></div><div class="pin-sub">Enter PIN</div>
<input type="password" class="pin-i" id="pinI" maxlength="8" placeholder="••••••" onkeydown="if(event.key==='Enter')chkPin()">
<button class="pin-go" onclick="chkPin()">Enter</button><div class="pin-e" id="pinE"></div></div></div>
<div id="app" style="display:none">
<div class="hdr"><div class="stars" id="hSt"></div><div style="position:relative;z-index:1"><div style="display:flex;justify-content:space-between;margin-bottom:10px"><div class="on-pill"><div class="pulse"></div> Online</div><button style="padding:4px 10px;border-radius:7px;font-size:.65rem;font-weight:700;cursor:pointer;background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.2);color:#fff" id="thBtn" onclick="tgTh()">☀️</button></div><div style="display:flex;flex-direction:column;align-items:center;gap:6px"><img src="https://lh3.googleusercontent.com/d/1HmBuyY8D5ccBUUAP-GsCuiTNxpxsaDsu" style="width:52px;height:52px;border-radius:14px;object-fit:cover;border:2px solid rgba(255,255,255,.2)"><div style="font-size:1.1rem;font-weight:800;color:#fff"><?= workerName ?></div><div style="font-size:.62rem;font-weight:600;color:rgba(255,255,255,.7);letter-spacing:.08em;text-transform:uppercase">Worker Panel · Joki Service</div></div></div></div>
<div class="notif-b" id="notifB">🔔 New order!</div>
<div class="tabs-s"><div class="tabs"><div class="tab on" data-tab="orders" onclick="sTab('orders')">Orders</div><div class="tab" data-tab="completed" onclick="sTab('completed')">Completed</div><div class="tab" data-tab="payroll" onclick="sTab('payroll')">Payroll</div><div class="tab" data-tab="reviews" onclick="sTab('reviews')">Reviews</div><div class="tab" data-tab="settings" onclick="sTab('settings')">Settings</div></div></div>
<div class="pnl on" id="p-orders"><div class="search-box"><input id="sO" placeholder="Search..." oninput="renderO()"></div><div id="oL"></div></div>
<div class="pnl" id="p-completed"><div class="sort-row"><button class="sort-btn on" onclick="cSort('newest',this)">Newest</button><button class="sort-btn" onclick="cSort('oldest',this)">Oldest</button><button class="sort-btn" onclick="cSort('product',this)">Product</button></div><div class="search-box"><input id="sC" placeholder="Search..." oninput="renderC()"></div><div id="cL"></div></div>
<div class="pnl" id="p-payroll"><div id="pL"></div></div>
<div class="pnl" id="p-reviews"><div id="rL"></div></div>
<div class="pnl" id="p-settings"><div class="set-c"><div style="font-size:.82rem;font-weight:700;margin-bottom:6px">⚙️ Status</div><div class="set-r"><select class="set-i" id="wSt" style="width:auto"><option value="Open">Open</option><option value="Close">Close</option></select><button class="set-b" onclick="setMySt()">Apply</button></div></div><div class="set-c" style="margin-top:10px"><div style="font-size:.82rem;font-weight:700;margin-bottom:8px">📦 Product Availability</div><div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--border)"><span style="font-size:.78rem">🏃 Candle Run</span><button class="set-b" id="pCRBtn" style="min-width:60px" onclick="toggleProd('Candle Run')">Open</button></div><div style="display:flex;justify-content:space-between;align-items:center;padding:6px 0"><span style="font-size:.78rem">⚡ Other Service</span><button class="set-b" id="pOtherBtn" style="min-width:60px" onclick="toggleProd('Other Service')">Open</button></div></div><div class="set-c" style="margin-top:10px"><div style="font-size:.82rem;font-weight:700">🔐 Change PIN</div><div class="set-r"><input type="password" class="set-i" id="oldP" placeholder="Current" maxlength="8"><input type="password" class="set-i" id="newP" placeholder="New (6+)" maxlength="8"><button class="set-b" onclick="chgP()">Save</button></div></div></div></div>
<input type="file" id="fInp" accept="image/*" style="display:none" onchange="handleFile(this)">
<div class="modal" id="imgM" onclick="this.classList.remove('on')"><img id="imgMI" src=""></div>
<div class="toast" id="toastEl"></div>
<script>
var W="<?= workerName ?>",_isDark=true,_uploadRec='',_lOC=-1,_cmpSort='newest',_ord=[],_cmp=[];
function playNotif(){try{var a=new(window.AudioContext||window.webkitAudioContext)(),o=a.createOscillator(),g=a.createGain();o.connect(g);g.connect(a.destination);o.frequency.value=880;o.type='sine';g.gain.setValueAtTime(.3,a.currentTime);g.gain.exponentialRampToValueAtTime(.001,a.currentTime+.3);o.start();o.stop(a.currentTime+.3)}catch(e){}}
(function(){var c=document.getElementById('hSt');for(var i=0;i<40;i++){var d=document.createElement('div');d.className='star';d.style.left=Math.random()*100+'%';d.style.top=Math.random()*100+'%';d.style.width=d.style.height=(1+Math.random()*1.5)+'px';d.style.opacity=(.15+Math.random()*.4);c.appendChild(d)}})();
function tgTh(){_isDark=!_isDark;document.documentElement.setAttribute('data-theme',_isDark?'':'light');document.getElementById('thBtn').textContent=_isDark?'☀️':'🌙'}
function esc(s){if(!s)return'';var d=document.createElement('div');d.textContent=String(s);return d.innerHTML}
function toast(m,t){var e=document.getElementById('toastEl');e.textContent=m;e.className='toast '+(t||'ok');e.classList.add('show');setTimeout(function(){e.classList.remove('show')},3000)}
function chkPin(){google.script.run.withSuccessHandler(function(r){if(r.success){document.getElementById('pinS').style.display='none';document.getElementById('app').style.display='block';load()}else{document.getElementById('pinE').style.display='block';document.getElementById('pinE').textContent=r.message||'Incorrect'}}).withFailureHandler(function(e){document.getElementById('pinE').style.display='block';document.getElementById('pinE').textContent=e.message}).verifyWorkerAccess(W,document.getElementById('pinI').value)}
function sTab(n){['orders','completed','payroll','reviews','settings'].forEach(function(t){var el=document.getElementById('p-'+t);if(el)el.classList.toggle('on',t===n)});document.querySelectorAll('.tab').forEach(function(t){t.classList.toggle('on',t.dataset.tab===n)});if(n==='payroll')loadPay();if(n==='reviews')loadRev()}
function load(){google.script.run.withSuccessHandler(function(data){var oc=data.orders.length;if(_lOC>=0&&oc>_lOC){playNotif();var nb=document.getElementById('notifB');nb.classList.add('show');setTimeout(function(){nb.classList.remove('show')},5000)}_lOC=oc;_ord=data.orders;_cmp=data.completed;renderO();renderC();if(data.status)document.getElementById('wSt').value=data.status;updateProdBtns(data.prodStatus);var oTab=document.querySelector('[data-tab="orders"]');if(oTab)oTab.innerHTML='Orders'+(oc?'<span class="tab-badge">'+oc+'</span>':'')}).withFailureHandler(function(e){toast(e.message,'er')}).getWorkerData(W)}
function renderO(){var q=(document.getElementById('sO').value||'').toLowerCase();var list=_ord;if(q)list=list.filter(function(o){return(o.record+o.customer+o.product).toLowerCase().indexOf(q)>=0});var el=document.getElementById('oL');if(!list.length){el.innerHTML='<div class="empty">No active orders</div>';return}el.innerHTML=list.map(function(o){var credH='';if(o.loginMethod==='Via Login'){credH='<div class="cred-box"><div style="font-size:.6rem;color:var(--muted);margin-bottom:2px">🔑 '+esc(o.loginPlatform)+'</div><div>'+esc(o.credentials)+'</div></div>'}else{credH='<div style="font-size:.72rem;color:var(--green);font-weight:700;margin:4px 0">🤝 Via Gandeng</div>'}var proofH='';if(o.proofs&&o.proofs.length){proofH='<div style="font-size:.68rem;color:var(--muted);margin-top:6px">📸 Photos ('+o.proofs.length+')</div><div class="proof-grid">';o.proofs.forEach(function(p){proofH+='<div class="proof-item"><img class="proof-thumb" src="'+p.image+'" onclick="document.getElementById(\'imgMI\').src=this.src;document.getElementById(\'imgM\').classList.add(\'on\')"><button class="proof-del" onclick="event.stopPropagation();delPhoto('+p.row+')">×</button></div>'});proofH+='</div>'}else{proofH='<div style="font-size:.68rem;color:var(--muted);margin-top:6px">📸 No photos yet</div>'}return'<div class="oc"><div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:4px"><div><div style="font-size:.92rem;font-weight:800">'+esc(o.customer)+'</div><div style="font-family:DM Mono,monospace;font-size:.68rem;color:var(--accent)">'+esc(o.record)+'</div></div><span style="font-size:.62rem;font-weight:700;color:var(--accent);padding:2px 8px;border-radius:5px;background:rgba(56,189,248,.1)">RUNNING</span></div><div style="display:flex;justify-content:space-between;font-size:.78rem;padding:6px 0;border-top:1px solid var(--border);margin-top:6px"><span style="font-weight:700">'+esc(o.product)+'</span><span style="font-size:.72rem;color:var(--muted)">'+esc(o.contact)+'</span></div>'+credH+(o.notes?'<div style="font-size:.68rem;color:var(--muted);margin-top:4px;font-style:italic">'+esc(o.notes)+'</div>':'')+proofH+'<div class="upload-area" onclick="startUpload(\''+esc(o.record)+'\')"><div style="font-size:1rem">📷</div><div style="font-size:.72rem;margin-top:4px">Tap to upload proof</div></div><button class="btn btn-g" onclick="markDone(\''+esc(o.record)+'\')" style="margin-top:8px">✅ Mark Done</button></div>'}).join('')}
function startUpload(rec){_uploadRec=rec;document.getElementById('fInp').click()}
function handleFile(input){if(!input.files||!input.files[0])return;var file=input.files[0];if(file.size>500000){toast('Max 500KB','er');input.value='';return}var reader=new FileReader();reader.onload=function(e){toast('Uploading...');google.script.run.withSuccessHandler(function(r){if(r.success){toast('Uploaded!');load()}else toast(r.message,'er')}).withFailureHandler(function(e){toast(e.message,'er')}).uploadProof(_uploadRec,W,e.target.result,'')};reader.readAsDataURL(file);input.value=''}
function delPhoto(row){if(!confirm('Delete photo?'))return;google.script.run.withSuccessHandler(function(r){toast(r.message,r.success?'ok':'er');if(r.success)load()}).withFailureHandler(function(e){toast(e.message,'er')}).deleteProof(row,W)}
function markDone(rec){if(!confirm('Mark '+rec+' completed?'))return;google.script.run.withSuccessHandler(function(r){toast(r.message,r.success?'ok':'er');if(r.success)load()}).withFailureHandler(function(e){toast(e.message,'er')}).markDone(rec,W)}
function cSort(s,el){_cmpSort=s;document.querySelectorAll('.sort-btn').forEach(function(b){b.classList.toggle('on',b===el)});renderC()}
function renderC(){var q=(document.getElementById('sC').value||'').toLowerCase();var list=_cmp.slice();if(q)list=list.filter(function(o){return(o.record+o.customer+o.product).toLowerCase().indexOf(q)>=0});if(_cmpSort==='oldest')list.reverse();if(_cmpSort==='product')list.sort(function(a,b){return(a.product||'').localeCompare(b.product||'')});var el=document.getElementById('cL');if(!list.length){el.innerHTML='<div class="empty">No completed</div>';return}el.innerHTML=list.map(function(o){var cd=o.completedDate?new Date(o.completedDate).toLocaleDateString('id-ID'):'—';return'<div class="oc"><div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:4px"><div><div style="font-size:.88rem;font-weight:800">'+esc(o.customer)+'</div><div style="font-family:DM Mono,monospace;font-size:.66rem;color:var(--accent)">'+esc(o.record)+'</div></div><span style="font-size:.75rem;font-weight:700">'+esc(o.product)+'</span></div><div class="inf"><span class="inf-l">Done</span><span class="inf-v" style="color:var(--green)">'+cd+'</span></div>'+(o.rating?'<div class="inf"><span class="inf-l">Rating</span><span class="inf-v" style="color:var(--yellow)">'+'★'.repeat(Number(o.rating))+'☆'.repeat(5-Number(o.rating))+'</span></div>':'')+'</div>'}).join('')}
function loadPay(){google.script.run.withSuccessHandler(function(months){document.getElementById('pL').innerHTML=months.length?months.map(function(m,mi){var finH='';if(m.finItems&&m.finItems.length){finH=m.finItems.map(function(f){var clr=f.amount>0?'var(--green)':'var(--red)';return'<div style="display:flex;justify-content:space-between;font-size:.7rem;padding:3px 8px;color:var(--muted)"><span>'+esc(f.date)+' · '+esc(f.type)+(f.notes?' — '+esc(f.notes):'')+'</span><span style="color:'+clr+'">'+f.amountF+'</span></div>'}).join('')}var delH='';if(m.delItems&&m.delItems.length){delH='<div style="margin-top:4px;cursor:pointer;font-size:.65rem;color:var(--accent);font-weight:700;padding:4px 0" onclick="var el=document.getElementById(\'pd'+mi+'\');el.style.display=el.style.display===\'none\'?\'block\':\'none\'">📋 '+m.delItems.length+' order(s) — tap to expand</div><div id="pd'+mi+'" style="display:none">'+m.delItems.map(function(d){return'<div style="display:flex;justify-content:space-between;font-size:.68rem;padding:3px 8px;color:var(--muted)"><span>'+esc(d.customer)+' <span style="font-size:.6rem">'+esc(d.product)+'</span></span><span style="color:var(--green)">'+d.earnF+'</span></div>'}).join('')+'</div>'}return'<div class="pr-c"><div class="pr-m">'+m.month+'</div><div class="pr-row"><span>Delivery</span><span>'+m.deliveryF+'</span></div>'+delH+'<div class="pr-row"><span>Bonus</span><span style="color:var(--green)">'+m.bonusF+'</span></div><div class="pr-row"><span>Deduction</span><span style="color:var(--red)">'+m.deductionF+'</span></div>'+finH+'<div class="pr-row" style="border-top:1px solid var(--border);padding-top:6px;margin-top:4px"><b>Total</b><b>'+m.totalF+'</b></div></div>'}).join(''):'<div class="empty">No payroll data</div>'}).withFailureHandler(function(e){toast(e.message,'er')}).getPayroll(W)}
function loadRev(){google.script.run.withSuccessHandler(function(reviews){var el=document.getElementById('rL');if(!reviews.length){el.innerHTML='<div class="empty">No reviews yet</div>';return}var avg=(reviews.reduce(function(s,r){return s+Number(r.rating)},0)/reviews.length).toFixed(1);var h='<div class="rv-card" style="text-align:center"><div style="font-size:1.5rem;color:var(--yellow)">'+avg+' ⭐</div><div style="font-size:.72rem;color:var(--muted)">'+reviews.length+' reviews</div></div>';reviews.forEach(function(r){h+='<div class="rv-card"><div style="display:flex;justify-content:space-between;align-items:center"><span style="font-weight:700;font-size:.82rem">'+esc(r.customer)+'</span><span style="color:var(--yellow);font-size:.82rem">'+'★'.repeat(Number(r.rating))+'☆'.repeat(5-Number(r.rating))+'</span></div><div style="font-size:.68rem;color:var(--muted);margin-top:2px">'+esc(r.product)+'</div>'+(r.feedback?'<div style="font-size:.72rem;color:var(--text);margin-top:4px;font-style:italic">"'+esc(r.feedback)+'"</div>':'')+'</div>'});el.innerHTML=h}).withFailureHandler(function(e){toast(e.message,'er')}).getWorkerFeedback(W)}
function setMySt(){google.script.run.withSuccessHandler(function(r){toast(r.message,r.success?'ok':'er')}).withFailureHandler(function(e){toast(e.message,'er')}).setWorkerStatus(W,document.getElementById('wSt').value)}
function chgP(){google.script.run.withSuccessHandler(function(r){toast(r.message,r.success?'ok':'er')}).withFailureHandler(function(e){toast(e.message,'er')}).changeWorkerPin(W,document.getElementById('oldP').value,document.getElementById('newP').value)}
function toggleProd(prod){var btn=prod==='Candle Run'?document.getElementById('pCRBtn'):document.getElementById('pOtherBtn');var cur=btn.textContent==='Open'?'Close':'Open';google.script.run.withSuccessHandler(function(r){toast(r.message,r.success?'ok':'er');if(r.success){btn.textContent=cur;btn.style.background=cur==='Open'?'var(--green)':'var(--red)'}}).withFailureHandler(function(e){toast(e.message,'er')}).setJokiProductStatus(W,prod,cur)}
function updateProdBtns(ps){if(!ps)return;[['pCRBtn',ps.crOpen],['pOtherBtn',ps.otherOpen]].forEach(function(m){var b=document.getElementById(m[0]);if(b){b.textContent=m[1]?'Open':'Close';b.style.background=m[1]?'var(--green)':'var(--red)'}})}
setInterval(load,15000);
</script></body></html>
