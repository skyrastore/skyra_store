function rateOrder(record,rating,feedback){if(!record)return{success:false,message:"Missing."};rating=parseInt(rating);if(isNaN(rating)||rating<1||rating>5)return{success:false,message:"1-5."};var sheet=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("JOKI_ORDERS"),data=sheet.getDataRange().getValues();for(var i=1;i<data.length;i++){if(data[i][JO_RECORD]===record){if(data[i][JO_STATUS]!=="Completed")return{success:false,message:"Only completed."};if(data[i][JO_RATING])return{success:false,message:"Already rated."};sheet.getRange(i+1,JO_RATING+1).setValue(rating);if(feedback){var fc=sheet.getLastColumn();if(fc<19)sheet.getRange(1,19).setValue("Feedback");sheet.getRange(i+1,19).setValue(String(feedback).substring(0,500));}return{success:true,message:"Thanks!"};}}return{success:false,message:"Not found."};}

// ── Finance ──
function getRevenueData(){var data=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("JOKI_ORDERS").getDataRange().getValues();var now=new Date();var wibNow=new Date(now.getTime()+7*36e5);var curYear=wibNow.getFullYear(),curMonth=wibNow.getMonth();var monthStart=new Date(Date.UTC(curYear,curMonth,1)-7*36e5);var days={},monthTotal=0,monthCount=0;for(var i=1;i<data.length;i++){if(!data[i][JO_RECORD])continue;if(data[i][JO_PAYMENT]!=="Paid")continue;if(data[i][JO_COMPLAINT]==="REFUND")continue;var upd=data[i][JO_UPDATED];if(!upd)continue;var ud=new Date(upd);if(ud<monthStart)continue;var dk=Utilities.formatDate(ud,"GMT+7","yyyy-MM-dd");var idr=Number(data[i][JO_PRICE_IDR])||0;if(!days[dk])days[dk]={date:dk,display:Utilities.formatDate(ud,"GMT+7","dd MMM"),count:0,idr:0,orders:[]};days[dk].count++;days[dk].idr+=idr;days[dk].orders.push({record:data[i][JO_RECORD],customer:data[i][JO_CUSTOMER]||"",product:data[i][JO_PRODUCT]||"",idr:idr});monthTotal+=idr;monthCount++;}var result=[];for(var k in days)result.push(days[k]);result.sort(function(a,b){return b.date.localeCompare(a.date);});var mNames=["January","February","March","April","May","June","July","August","September","October","November","December"];var wPerf={};var wList=getAllWorkers();for(var wi=0;wi<wList.length;wi++)wPerf[wList[wi].name]={name:wList[wi].name,orders:{}};for(var i=1;i<data.length;i++){if(!data[i][JO_RECORD]||data[i][JO_STATUS]!=="Completed")continue;var w=data[i][JO_WORKER];if(!w||w==="Admin")continue;var upd2=data[i][JO_UPDATED];if(!upd2||new Date(upd2)<monthStart)continue;if(!wPerf[w])wPerf[w]={name:w,orders:{}};wPerf[w].orders[data[i][JO_RECORD]]=true;}var ratingData={};for(var i=1;i<data.length;i++){if(!data[i][JO_WORKER]||!data[i][JO_RATING])continue;var rw=data[i][JO_WORKER];if(!ratingData[rw])ratingData[rw]={total:0,count:0};ratingData[rw].total+=Number(data[i][JO_RATING]);ratingData[rw].count++;}var wBoard=[];for(var w in wPerf){var p=wPerf[w];var rd=ratingData[w]||{total:0,count:0};wBoard.push({name:p.name,orderCount:Object.keys(p.orders).length,avgRating:rd.count>0?Math.round(rd.total/rd.count*10)/10:0,ratingCount:rd.count});}var rates=getWorkerRates();var payrollCost=0;for(var i=1;i<data.length;i++){if(!data[i][JO_RECORD])continue;if(data[i][JO_PAYMENT]!=="Paid")continue;if(data[i][JO_COMPLAINT]==="REFUND")continue;if(data[i][JO_STATUS]!=="Completed")continue;var upd3=data[i][JO_UPDATED];if(!upd3||new Date(upd3)<monthStart)continue;payrollCost+=rates[data[i][JO_PRODUCT]||""]||0;}var netProfit=monthTotal-payrollCost;var paidOut=0;var finSheet=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("JokiFinance");if(finSheet){var finData=finSheet.getDataRange().getValues();for(var i=1;i<finData.length;i++){if(!finData[i][0])continue;var fDate=new Date(finData[i][0]);if(fDate<monthStart)continue;paidOut+=Number(finData[i][3])||0;}}var unpaidBal=payrollCost-paidOut;wBoard.sort(function(a,b){return b.orderCount-a.orderCount});return{days:result,monthTotal:monthTotal,monthTotalF:formatIDR(monthTotal),monthCount:monthCount,monthName:mNames[curMonth]+" "+curYear,leaderboard:wBoard,payrollCost:payrollCost,payrollCostF:formatIDR(payrollCost),paidOut:paidOut,paidOutF:formatIDR(paidOut),unpaidBal:unpaidBal,unpaidBalF:formatIDR(unpaidBal),netProfit:netProfit,netProfitF:formatIDR(netProfit)};}
function getPayroll(worker){var ss=SpreadsheetApp.getActiveSpreadsheet();var data=ss.getSheetByName("JOKI_ORDERS").getDataRange().getValues();var finance=ss.getSheetByName("JokiFinance").getDataRange().getValues();var rates=getWorkerRates();var months={};for(var i=1;i<data.length;i++){if(!data[i][JO_RECORD]||data[i][JO_WORKER]!==worker||data[i][JO_STATUS]!=="Completed")continue;var upd=data[i][JO_UPDATED];if(!upd)continue;var mk=Utilities.formatDate(new Date(upd),"GMT+7","yyyy-MM");if(!months[mk])months[mk]={delivery:0,bonus:0,deduction:0,finItems:[],delItems:[]};var pr=data[i][JO_PRODUCT]||"";var rate=rates[pr]||0;months[mk].delivery+=rate;months[mk].delItems.push({record:data[i][JO_RECORD],customer:data[i][JO_CUSTOMER]||"",product:pr,earn:rate,earnF:formatIDR(rate)});}for(var i=1;i<finance.length;i++){if(String(finance[i][1])!==worker||!finance[i][0])continue;var mk2=Utilities.formatDate(new Date(finance[i][0]),"GMT+7","yyyy-MM");if(!months[mk2])months[mk2]={delivery:0,bonus:0,deduction:0,finItems:[],delItems:[]};var amt=Number(finance[i][3])||0;var fDate=Utilities.formatDate(new Date(finance[i][0]),"GMT+7","dd MMM");months[mk2].finItems.push({date:fDate,type:String(finance[i][2]),amount:amt,amountF:formatIDR(Math.abs(amt)),notes:String(finance[i][4]||"")});if(amt>0)months[mk2].bonus+=amt;else months[mk2].deduction+=amt;}var result=[];for(var k in months){var m=months[k];m.delItems.sort(function(a,b){return b.earn-a.earn});result.push({month:k,delivery:m.delivery,bonus:m.bonus,deduction:m.deduction,total:m.delivery+m.bonus+m.deduction,deliveryF:formatIDR(m.delivery),bonusF:formatIDR(m.bonus),deductionF:formatIDR(m.deduction),totalF:formatIDR(m.delivery+m.bonus+m.deduction),finItems:m.finItems||[],delItems:m.delItems});}result.sort(function(a,b){return b.month.localeCompare(a.month);});return result;}
function getWorkerFeedback(worker){var data=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("JOKI_ORDERS").getDataRange().getValues(),out=[];for(var i=1;i<data.length;i++){if(!data[i][JO_RECORD]||data[i][JO_WORKER]!==worker||!data[i][JO_RATING])continue;out.push({record:data[i][JO_RECORD],customer:data[i][JO_CUSTOMER],product:data[i][JO_PRODUCT],rating:data[i][JO_RATING],feedback:data[i][18]||""});}out.reverse();return out.slice(0,30);}
