function requestRefund(record,reason,bankName,bankAccount){var sheet=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("JOKI_ORDERS"),data=sheet.getDataRange().getValues();for(var i=1;i<data.length;i++){if(data[i][JO_RECORD]===record){var st=data[i][JO_STATUS],pay=data[i][JO_PAYMENT];if(pay!=="Paid")return{success:false,message:"Not paid."};if(st!=="Pending"&&st!=="Waiting Payment")return{success:false,message:"Cannot refund after processing started."};var nm=String(data[i][JO_NOTES]||"");if(nm.indexOf("Pay:Wise")>=0)return{success:false,message:"Wise payments are non-refundable."};if(String(data[i][JO_COMPLAINT]).indexOf("REFUND")>=0)return{success:false,message:"Refund already requested."};var refObj={reason:sanitize(reason,60),bank:sanitize(bankName,50),account:sanitize(bankAccount,50)};sheet.getRange(i+1,JO_COMPLAINT+1).setValue("REFUND_REQUEST:"+JSON.stringify(refObj));sheet.getRange(i+1,JO_UPDATED+1).setValue(new Date());return{success:true,message:"Refund requested!"};}}return{success:false,message:"Not found."};}
function getRefundRequests(){var data=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("JOKI_ORDERS").getDataRange().getValues(),out=[];for(var i=1;i<data.length;i++){if(!data[i][JO_RECORD])continue;var c=String(data[i][JO_COMPLAINT]||"");if(c.indexOf("REFUND_REQUEST")!==0)continue;var reason="",bankName="",bankAccount="";try{var obj=JSON.parse(c.replace("REFUND_REQUEST:",""));reason=obj.reason||"";bankName=obj.bank||"";bankAccount=obj.account||"";}catch(e){reason=c.replace("REFUND_REQUEST:","");}var nm=String(data[i][JO_NOTES]||"");var pmMatch=nm.match(/Pay:(\w+)/);out.push({row:i+1,record:data[i][JO_RECORD],customer:data[i][JO_CUSTOMER],contact:data[i][JO_CONTACT]||"",product:data[i][JO_PRODUCT],status:data[i][JO_STATUS],priceIDR:data[i][JO_PRICE_IDR]||0,priceUSD:data[i][JO_PRICE_USD]||0,paymentMethod:pmMatch?pmMatch[1]:"",bankName:bankName,bankAccount:bankAccount,reason:reason});}out.reverse();return out;}
function approveRefund(record){var sheet=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("JOKI_ORDERS"),data=sheet.getDataRange().getValues();for(var i=1;i<data.length;i++){if(data[i][JO_RECORD]===record&&String(data[i][JO_COMPLAINT]).indexOf("REFUND_REQUEST")===0){sheet.getRange(i+1,JO_STATUS+1).setValue("Cancelled");sheet.getRange(i+1,JO_COMPLAINT+1).setValue("REFUND");sheet.getRange(i+1,JO_UPDATED+1).setValue(new Date());return{success:true,message:"Refund approved: "+record};}}return{success:false,message:"Not found."};}
function rejectRefund(record){var sheet=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("JOKI_ORDERS"),data=sheet.getDataRange().getValues();for(var i=1;i<data.length;i++){if(data[i][JO_RECORD]===record&&String(data[i][JO_COMPLAINT]).indexOf("REFUND_REQUEST")===0){sheet.getRange(i+1,JO_COMPLAINT+1).setValue("REFUND_REJECTED");sheet.getRange(i+1,JO_UPDATED+1).setValue(new Date());return{success:true,message:"Refund rejected: "+record};}}return{success:false,message:"Not found."};}

// ── Customer Track / History (smarter contact match) ──
function checkOrder(record){var ss=SpreadsheetApp.getActiveSpreadsheet();var sheets=["JOKI_ORDERS","Archive_JokiOrders"];var order=null,stg=getStoreSettings();for(var s=0;s<sheets.length;s++){var sh=ss.getSheetByName(sheets[s]);if(!sh)continue;var data=sh.getDataRange().getValues();for(var i=1;i<data.length;i++){if(data[i][JO_RECORD]===record){var wk=data[i][JO_WORKER]||"";var st=data[i][JO_STATUS];var pay=data[i][JO_PAYMENT]||"";var waGrp="";if(pay==="Paid"&&(st==="Running"||st==="Completed")&&wk){waGrp=String(stg["WA Group "+wk]||"").trim();}order={customer:data[i][JO_CUSTOMER],contact:data[i][JO_CONTACT]||"",product:data[i][JO_PRODUCT],loginMethod:data[i][JO_LOGIN_METHOD]||"",status:st,worker:wk||"Assigning...",time:data[i][JO_TIME]?data[i][JO_TIME].toString():"",payment:pay,priceIDR:data[i][JO_PRICE_IDR]||0,priceUSD:data[i][JO_PRICE_USD]||0,waGroupUrl:waGrp,notes:data[i][JO_NOTES]||"",complaint:String(data[i][JO_COMPLAINT]||""),rating:data[i][JO_RATING]||"",feedback:data[i][18]||""};break;}}if(order)break;}if(!order)return{order:null,proofs:[],queuePos:null};var proofs=[];if(order.payment==="Paid")proofs=getProofs(record);var queuePos=null;if(order.status==="Running"||order.status==="Pending"){var ordData=ss.getSheetByName("JOKI_ORDERS").getDataRange().getValues();var pos=0,total=0;for(var i=1;i<ordData.length;i++){if(!ordData[i][JO_RECORD])continue;var s2=ordData[i][JO_STATUS];if(s2==="Running"||s2==="Pending"){total++;if(ordData[i][JO_RECORD]===record)pos=total;}}queuePos={position:pos,total:total,ahead:pos>0?pos-1:0};}return{order:order,proofs:proofs,queuePos:queuePos,whatsapp:stg["Whatsapp"]?String(stg["Whatsapp"]).replace(/\.0$/,""):""};}
function getOrderHistory(contact){if(!contact)return[];contact=String(contact).trim();var raw=contact.replace(/^\+/,"");var co=raw.replace(/^0+/,"");var coFull=co.match(/^62/)?co:"62"+co;var ss=SpreadsheetApp.getActiveSpreadsheet();var sheetNames=["JOKI_ORDERS","Archive_JokiOrders"];var out=[];for(var s=0;s<sheetNames.length;s++){var sh=ss.getSheetByName(sheetNames[s]);if(!sh)continue;var data=sh.getDataRange().getValues();for(var i=1;i<data.length;i++){if(!data[i][JO_RECORD])continue;var stored=String(data[i][JO_CONTACT]||"");var custName=String(data[i][JO_CUSTOMER]||"").toLowerCase();var match=stored===contact||stored===raw||stored===co||stored===coFull||stored.replace(/^\+/,"").replace(/^0+/,"")===co||custName===contact.toLowerCase();if(match){out.push({record:data[i][JO_RECORD],product:data[i][JO_PRODUCT],status:data[i][JO_STATUS],payment:data[i][JO_PAYMENT]||"",time:data[i][JO_TIME]?data[i][JO_TIME].toString():"",priceIDR:data[i][JO_PRICE_IDR]||0});}}}out.sort(function(a,b){return(b.time||"").localeCompare(a.time||"")});return out.slice(0,50);}

