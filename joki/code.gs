var SCRIPT_PROP=PropertiesService.getScriptProperties();
var JO_RECORD=0,JO_TIME=1,JO_CUSTOMER=2,JO_CONTACT=3,JO_PRODUCT=4,JO_LOGIN_METHOD=5,JO_LOGIN_PLATFORM=6,JO_CREDENTIALS=7,JO_PAYMENT=8,JO_WORKER=9,JO_STATUS=10,JO_COMPLAINT=11,JO_SOURCE=12,JO_NOTES=13,JO_UPDATED=14,JO_PRICE_IDR=15,JO_PRICE_USD=16,JO_RATING=17;
