function getWorkerData(name){var ss=SpreadsheetApp.getActiveSpreadsheet();var data=ss.getSheetByName("JOKI_ORDERS").getDataRange().getValues();var orders=[],completed=[];for(var i=1;i<data.length;i++){if(!data[i][JO_RECORD]||data[i][JO_WORKER]!==name)continue;if(data[i][JO_STATUS]==="Running"){var cred=String(data[i][JO_CREDENTIALS]||"");var lm=data[i][JO_LOGIN_METHOD]||"";var lp="",cr="";if(lm==="Via Login"&&cred.indexOf("||")>=0){var parts=cred.split("||");lp=parts[0];cr=parts[1];}orders.push({row:i+1,record:data[i][JO_RECORD],customer:data[i][JO_CUSTOMER]||"",contact:data[i][JO_CONTACT]||"",product:data[i][JO_PRODUCT]||"",loginMethod:lm,loginPlatform:lp,credentials:cr,time:data[i][JO_TIME]?data[i][JO_TIME].toString():"",notes:String(data[i][JO_NOTES]||"").replace(/Pay:\w+\s*/g,"").replace(/\[RETURNING[^\]]*\]\s*/g,"").trim()});}if(data[i][JO_STATUS]==="Completed"){completed.push({record:data[i][JO_RECORD],customer:data[i][JO_CUSTOMER]||"",product:data[i][JO_PRODUCT]||"",rating:data[i][JO_RATING]||"",completedDate:data[i][JO_UPDATED]?new Date(data[i][JO_UPDATED]).toISOString():""});}}completed.sort(function(a,b){return(b.completedDate||"").localeCompare(a.completedDate||"")});if(completed.length>50)completed=completed.slice(0,50);var proofs=ss.getSheetByName("JOKI_PROOF").getDataRange().getValues();var proofsByRec={};for(var i=1;i<proofs.length;i++){if(!proofs[i][JP_RECORD]||proofs[i][JP_WORKER]!==name)continue;var rec=proofs[i][JP_RECORD];if(!proofsByRec[rec])proofsByRec[rec]=[];proofsByRec[rec].push({row:i+1,time:proofs[i][JP_TIME]?Utilities.formatDate(new Date(proofs[i][JP_TIME]),"GMT+7","dd MMM HH:mm"):"",image:proofs[i][JP_IMAGE]||"",notes:proofs[i][JP_NOTES]||""});}orders.forEach(function(o){o.proofs=proofsByRec[o.record]||[];});var myStatus="Open";var myCR=true,myOther=true;var wRows=ss.getSheetByName("JokiWorkers").getDataRange().getValues();for(var i=1;i<wRows.length;i++){if(wRows[i][1]===name){myStatus=String(wRows[i][2])||"Open";myCR=String(wRows[i][3]||"Open")==="Open";myOther=String(wRows[i][4]||"Open")==="Open";break;}}return{orders:orders,completed:completed,status:myStatus,prodStatus:{crOpen:myCR,otherOpen:myOther}};}
function getProofs(record){var data=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("JOKI_PROOF").getDataRange().getValues();var out=[];for(var i=1;i<data.length;i++){if(data[i][JP_RECORD]===record){out.push({time:data[i][JP_TIME]?Utilities.formatDate(new Date(data[i][JP_TIME]),"GMT+7","dd MMM HH:mm"):"",worker:data[i][JP_WORKER]||"",image:data[i][JP_IMAGE]||"",notes:data[i][JP_NOTES]||""});}}return out;}
function markDone(record,worker){var sheet=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("JOKI_ORDERS"),data=sheet.getDataRange().getValues();for(var i=1;i<data.length;i++){if(data[i][JO_RECORD]===record&&data[i][JO_WORKER]===worker&&data[i][JO_STATUS]==="Running"){sheet.getRange(i+1,JO_STATUS+1).setValue("Completed");sheet.getRange(i+1,JO_UPDATED+1).setValue(new Date());return{success:true,message:"Completed!"};}}return{success:false,message:"Not found."};}
