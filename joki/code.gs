function getErrorLogs(){var ss=SpreadsheetApp.getActiveSpreadsheet();var sheet=ss.getSheetByName("ErrorLogs");if(!sheet)return[];var data=sheet.getDataRange().getValues(),out=[];for(var i=1;i<data.length;i++){out.push({time:data[i][0]?data[i][0].toString():"",fn:data[i][1]||"",error:data[i][2]||"",context:data[i][3]||""});}out.reverse();return out.slice(0,50);}

// ── [2] Auto-Cancel Unpaid 24h ──
function autoCancelUnpaidOrders(){var sheet=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("JOKI_ORDERS"),data=sheet.getDataRange().getValues(),now=new Date();for(var i=1;i<data.length;i++){if(data[i][JO_STATUS]!=="Waiting Payment"||!data[i][JO_TIME])continue;if((now-new Date(data[i][JO_TIME]))/36e5>24){sheet.getRange(i+1,JO_STATUS+1).setValue("Cancelled");sheet.getRange(i+1,JO_UPDATED+1).setValue(now);}}}

// ── [4] Archive Old Data ──
function archiveOldData(){var ss=SpreadsheetApp.getActiveSpreadsheet();var now=new Date();var cutoff=new Date(now.getTime()-60*864e5);var master=ss.getSheetByName("JOKI_ORDERS");var arcO=ss.getSheetByName("Archive_JokiOrders");if(!arcO){arcO=ss.insertSheet("Archive_JokiOrders");arcO.appendRow(["Record","Time","Customer","Contact","Product","LoginMethod","LoginPlatform","Credentials","Payment","Worker","Status","Complaint","Source","Notes","Updated","PriceIDR","PriceUSD","Rating","Feedback"]);}var mData=master.getDataRange().getValues();var archived=0;var delRows=[];for(var i=mData.length-1;i>=1;i--){if(mData[i][JO_STATUS]!=="Completed"&&mData[i][JO_STATUS]!=="Cancelled")continue;var upd=mData[i][JO_UPDATED];if(!upd||new Date(upd)>cutoff)continue;arcO.appendRow(mData[i]);delRows.push(i+1);archived++;}for(var i=0;i<delRows.length;i++)master.deleteRow(delRows[i]);Logger.log("Archived "+archived+" joki orders");}

// ── [11] Consistency Check ──
function checkConsistency(){var data=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("JOKI_ORDERS").getDataRange().getValues();var issues=[];for(var i=1;i<data.length;i++){if(!data[i][JO_RECORD])continue;var st=data[i][JO_STATUS],pay=data[i][JO_PAYMENT],wk=data[i][JO_WORKER];if(st==="Running"&&!wk)issues.push("NO_WORKER: "+data[i][JO_RECORD]+" is Running but has no worker");if(st==="Running"&&pay!=="Paid")issues.push("UNPAID_RUNNING: "+data[i][JO_RECORD]+" is Running but not Paid");}if(issues.length>0)logError("checkConsistency",{message:issues.join("; ")},{count:issues.length});return issues;}

// ── [11] Setup Triggers ──
function setupTriggers(){ScriptApp.getProjectTriggers().forEach(function(t){ScriptApp.deleteTrigger(t);});ScriptApp.newTrigger("autoCancelUnpaidOrders").timeBased().everyHours(6).create();ScriptApp.newTrigger("archiveOldData").timeBased().onMonthDay(1).atHour(3).create();ScriptApp.newTrigger("checkConsistency").timeBased().everyHours(12).create();}
