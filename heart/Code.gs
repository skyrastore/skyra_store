function checkLock(key){var ld=SCRIPT_PROP.getProperty("LOCK_"+key);if(!ld)return false;var d=JSON.parse(ld);if(d.c>=5){if((new Date().getTime()-d.t)<900000)return true;SCRIPT_PROP.deleteProperty("LOCK_"+key);}return false;}
