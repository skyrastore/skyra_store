function verifyWorkerAccess(name,pin){try{var lk="W_"+name;if(checkLock(lk))return{success:false,locked:true,message:"Locked 15 min."};var s=getStoreSettings();var ap=String(s["Admin PIN"]||"").replace(/\.0$/,"").trim();if(ap&&String(pin).trim()===ap){clearLock(lk);return{success:true,role:"admin"};}var wp=String(s["Worker "+name+" PIN"]||"").replace(/\.0$/,"").trim();if(!wp||wp==="0"){clearLock(lk);return{success:true,role:"worker"};}if(String(pin).trim()===wp){clearLock(lk);return{success:true,role:"worker"};}addFail(lk);return{success:false,message:"Incorrect PIN."};}catch(e){return{success:false,message:"Error: "+e.message};}}
