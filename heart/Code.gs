function markAllPaidByContact(contact){var sheet=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("MASTER_ORDERS"),data=sheet.getDataRange().getValues();var count=0;for(var i=1;i<data.length;i++){if(data[i][MO_STATUS]==="Waiting Payment"&&String(data[i][MO_CONTACT])===contact){sheet.getRange(i+1,MO_PAYMENT+1).setValue("Paid");sheet.getRange(i+1,MO_STATUS+1).setValue("Pending");sheet.getRange(i+1,MO_UPDATED+1).setValue(new Date());count++;}}if(count>0){logDelivery("SYSTEM","Admin","Bulk Paid",count,"Bulk paid "+count+" orders for "+contact);try{orderRouter();}catch(e){}}return{success:count>0,count:count,message:count>0?count+" orders marked paid.":"No unpaid orders found."};}
function reassignWorker(record,newWorker){var lock=LockService.getScriptLock();if(!lock.tryLock(10000))return{success:false,message:"Server busy."};try{var ss=SpreadsheetApp.getActiveSpreadsheet();var wList=getWorkers();var wObj=null;for(var w=0;w<wList.length;w++){if(wList[w].name===newWorker){wObj=wList[w];break;}}if(!wObj)return{success:false,message:newWorker+" not found or inactive."};var sheet=ss.getSheetByName("MASTER_ORDERS"),data=sheet.getDataRange().getValues();for(var i=1;i<data.length;i++){if(data[i][MO_RECORD]!==record)continue;var prod=data[i][MO_PRODUCT],oldW=data[i][MO_WORKER];if(oldW===newWorker)return{success:false,message:"Already assigned to "+newWorker};var lim=prod==="Heart Instant"?wObj.instantLimit:prod==="Heart Special"?wObj.specialLimit:wObj.regulerLimit;if(lim<=0)return{success:false,message:newWorker+" cannot handle "+prod+"."};sheet.getRange(i+1,MO_WORKER+1).setValue(newWorker);sheet.getRange(i+1,MO_UPDATED+1).setValue(new Date());var qName=prod==="Heart Instant"?"InstantQueue":prod==="Heart Special"?"SpecialQueue":"RegulerQueue";var wCol=qName==="RegulerQueue"?RQ_WORKER:Q_WORKER;var qSheet=ss.getSheetByName(qName);var qData=qSheet.getDataRange().getValues();for(var j=1;j<qData.length;j++){if(qData[j][0]===record){qSheet.getRange(j+1,wCol+1).setValue(newWorker);break;}}logDelivery(record,"Admin","Reassign",0,"Reassigned: "+oldW+" → "+newWorker);return{success:true,message:"Reassigned to "+newWorker};}return{success:false,message:"Not found."};}finally{lock.releaseLock();}}
