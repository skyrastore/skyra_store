function checkConsistency(){var ss=SpreadsheetApp.getActiveSpreadsheet();var master=ss.getSheetByName("MASTER_ORDERS").getDataRange().getValues();var iq=ss.getSheetByName("InstantQueue").getDataRange().getValues();var sq=ss.getSheetByName("SpecialQueue").getDataRange().getValues();var rq=ss.getSheetByName("RegulerQueue").getDataRange().getValues();var issues=[];var qRecs={};for(var i=1;i<iq.length;i++){if(iq[i][Q_RECORD]&&iq[i][Q_STATUS]!=="Completed")qRecs[iq[i][Q_RECORD]]="InstantQueue";}for(var i=1;i<sq.length;i++){if(sq[i][Q_RECORD]&&sq[i][Q_STATUS]!=="Completed")qRecs[sq[i][Q_RECORD]]="SpecialQueue";}for(var i=1;i<rq.length;i++){if(rq[i][RQ_RECORD]&&rq[i][RQ_STATUS]!=="Done")qRecs[rq[i][RQ_RECORD]]="RegulerQueue";}for(var i=1;i<master.length;i++){var rec=master[i][MO_RECORD],st=master[i][MO_STATUS];if(!rec)continue;if(st==="Running"&&!qRecs[rec])issues.push("ORPHAN: "+rec+" is Running but not in any queue");if(st==="Cancelled"&&qRecs[rec])issues.push("GHOST: "+rec+" is Cancelled but still in "+qRecs[rec]);}if(issues.length>0)logError("checkConsistency",{message:issues.join("; ")},{count:issues.length});return issues;}
function setupTriggers(){ScriptApp.getProjectTriggers().forEach(function(t){ScriptApp.deleteTrigger(t);});ScriptApp.newTrigger("runDeliverySystem").timeBased().everyMinutes(5).create();ScriptApp.newTrigger("autoCancelUnpaidOrders").timeBased().everyHours(6).create();ScriptApp.newTrigger("autoExpireSpecial").timeBased().everyHours(1).create();ScriptApp.newTrigger("autoClaimDeliveries").timeBased().everyHours(6).create();ScriptApp.newTrigger("cleanupEmptyRows").timeBased().everyHours(12).create();ScriptApp.newTrigger("archiveOldData").timeBased().onMonthDay(1).atHour(3).create();ScriptApp.newTrigger("checkConsistency").timeBased().everyHours(12).create();}
