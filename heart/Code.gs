function submitNewOrder(od){try{var cu=sanitize(od.customer,100),co=sanitize(od.contact,50),ct=sanitize(od.contactType,10)||"WhatsApp",pm=sanitize(od.paymentMethod,20)||"QRIS",cd=sanitize(od.code,500),pr=sanitize(od.product,30),qt=parseInt(od.qty),nt=sanitize(od.notes,60);if(ct==="WhatsApp")co=co.replace(/[^0-9+]/g,"");if(isBlacklisted(co))return{success:false,message:"Contact blocked."};if(!cu||cu.length<2)return{success:false,message:"Name min 2 chars."};if(!co||co.length<3)return{success:false,message:"Invalid contact."};if(!cd||cd.length<2)return{success:false,message:"Invalid code."};if(["Heart Instant","Heart Special","Heart Reguler"].indexOf(pr)===-1)return{success:false,message:"Invalid product."};var tiers=getPriceList()[pr];if(!tiers)return{success:false,message:"Not found."};var tier=null;for(var t=0;t<tiers.length;t++){if(tiers[t].qty===qt){tier=tiers[t];break;}}if(!tier)return{success:false,message:"Invalid tier."};var s=getStoreSettings();if(String(s["Store Open"]).toLowerCase()==="false")return{success:false,message:"Store closed."};if(pr==="Heart Special"&&String(s["Special Available"]).toLowerCase()==="false")return{success:false,message:"Special unavailable."};if(pr==="Heart Special"){var spSlots=countActiveSpecialSlots();var spPend=0;var moCheck=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("MASTER_ORDERS").getDataRange().getValues();for(var x=1;x<moCheck.length;x++){if(moCheck[x][MO_PRODUCT]==="Heart Special"&&moCheck[x][MO_STATUS]==="Pending"&&moCheck[x][MO_PAYMENT]==="Paid")spPend++;if(moCheck[x][MO_PRODUCT]==="Heart Special"&&moCheck[x][MO_STATUS]==="Waiting Payment")spPend++;}if(spSlots+spPend>=SPECIAL_MAX_ACTIVE)return{success:false,message:"Special queue full. Max "+SPECIAL_MAX_ACTIVE+" active."};}var now=new Date(),sheet=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("MASTER_ORDERS"),allData=sheet.getDataRange().getValues();var rc=0;for(var i=allData.length-1;i>=1;i--){if(!allData[i][MO_TIME])continue;if((now-new Date(allData[