function getOrderHistory(contact){if(!contact)return[];contact=String(contact).trim();var raw=contact.replace(/^\+/,"");var co=raw.replace(/^0+/,"");var coFull=co.match(/^62/)?co:"62"+co;var ss=SpreadsheetApp.getActiveSpreadsheet();var sheetNames=["MASTER_ORDERS","Archive_Orders"];var out=[];for(var s=0;s<sheetNames.length;s++){var sh=ss.getSheetByName(sheetNames[s]);if(!sh)continue;var data=sh.getDataRange().getValues();for(var i=1;i<data.length;i++){if(!data[i][MO_RECORD])continue;var stored=String(data[i][MO_CONTACT]||"");var custName=String(data[i][MO_CUSTOMER]||"").toLowerCase();var match=stored===contact||stored===raw||stored===co||stored===coFull||stored.replace(/^\+/,"").replace(/^0+/,"")===co||custName===contact.toLowerCase();if(match){out.push({record:data[i][MO_RECORD],product:data[i][MO_PRODUCT],qty:data[i][MO_QTY],status:data[i][MO_STATUS],payment:data[i][MO_PAYMENT]||"",time:data[i][MO_TIME]?data[i][MO_TIME].toString():"",priceIDR:data[i][MO_PRICE_IDR]||0});}}}out.sort(function(a,b){return(b.time||"").localeCompare(a.time||"")});return out.slice(0,50);}
function archiveOldData(){var ss=SpreadsheetApp.getActiveSpreadsheet();var now=new Date();var cutoff=new Date(now.getTime()-60*864e5);var master=ss.getSheetByName("MASTER_ORDERS");var dl=ss.getSheetByName("DeliveryLogs_MASTER");var iq=ss.getSheetByName("InstantQueue");var sq=ss.getSheetByName("SpecialQueue");var arcO=ss.getSheetByName("Archive_Orders");if(!arcO){arcO=ss.insertSheet("Archive_Orders");arcO.appendRow(["Record","Time","Customer","Contact","Code","Product","Type","Qty","Payment","Worker","Status","Complaint","Source","Notes","Updated","PriceIDR","PriceUSD","Rating","Feedback"]);}var arcL=ss.getSheetByName("Archive_Logs");if(!arcL){arcL=ss.insertSheet("Archive_Logs");arcL.appendRow(["Time","Record","Product","Worker","Bot","Amount","Status","Claimed"]);}var mData=master.getDataRange().getValues();var archived={};var delRows=[];for(var i=mData.length-1;i>=1;i--){if(mData[i][MO_STATUS]!=="Completed"&&mData[i][MO_STATUS]!=="Cancelled")continue;var upd=mData[i][MO_UPDATED];if(!upd||new Date(upd)>cutoff)continue;arcO.appendRow(mData[i]);archived[mData[i][MO_RECORD]]=true;delRows.push(i+1);}for(var i=0;i<delRows.length;i++)master.deleteRow(delRows[i]);var lData=dl.getDataRange().getValues();var delL=[];for(var i=lData.length-1;i>=1;i--){if(archived[lData[i][DL_RECORD]]){arcL.appendRow(lData[i]);delL.push(i+1);}}for(var i=0;i<delL.length;i++)dl.deleteRow(delL[i]);var qSheets=[iq,sq];for(var s=0;s<qSheets.length;s++){var qd=qSheets[s].getDataRange().getValues();for(var i=qd.length-1;i>=1;i--){if(qd[i][Q_STATUS]==="Completed")qSheets[s].deleteRow(i+1);}}var rq=ss.getSheetByName("RegulerQueue"),rqd=rq.getDataRange().getValues();for(var i=rqd.length-1;i>=1;i--){if(rqd[i][RQ_STATUS]==="Done"&&archived[rqd[i][RQ_RECORD]])rq.deleteRow(i+1);}Logger.log("Archived "+Object.keys(archived).length+" orders");}
function autoClaimDeliveries(){var sheet=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("DeliveryLogs_MASTER");var data=sheet.getDataRange().getValues();var now=new Date();var srh=getSkyResetHour();var lastReset=new Date(now);lastReset.setUTCHours(srh-7,0,0,0);if(now<lastReset)lastReset=new Date(lastReset.getTime()-864e5);var count=0;for(var i=1;i<data.length;i++){if(!data[i][DL_RECORD]||data[i][DL_RECORD]==="SYSTEM")continue;if(data[i][DL_CLAIMED])continue;if(String(data[i][DL_STATUS]).indexOf("Adjustment")>=0)continue;if(Number(data[i][DL_AMOUNT])<=0)continue;var t=data[i][DL_TIME];if(!t)continue;if(new Date(t)<lastReset){sheet.getRange(i+1,DL_CLAIMED+1).setValue("System");count++;}}if(count>0)Logger.log("Auto-claimed "+count+" deliveries");}
