function requestRefund(record,reason,bankName,bankAccount){var sheet=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("MASTER_ORDERS"),data=sheet.getDataRange().getValues();for(var i=1;i<data.length;i++){if(data[i][MO_RECORD]===record){var st=data[i][MO_STATUS],pay=data[i][MO_PAYMENT];if(pay!=="Paid")return{success:false,message:"Not paid."};if(st!=="Pending")return{success:false,message:"Cannot refund after processing started."};var nm=String(data[i][MO_NOTES]||"");if(nm.indexOf("Pay:Wise")>=0)return{success:false,message:"Wise payments are non-refundable."};if(st==="Cancelled")return{success:false,message:"Already cancelled."};if(String(data[i][MO_COMPLAINT]).indexOf("REFUND")>=0)return{success:false,message:"Refund already requested."};var refObj={reason:sanitize(reason,60),bank:sanitize(bankName,50),account:sanitize(bankAccount,50)};sheet.getRange(i+1,MO_COMPLAINT+1).setValue("REFUND_REQUEST:"+JSON.stringify(refObj));sheet.getRange(i+1,MO_UPDATED+1).setValue(new Date());return{success:true,message:"Refund requested!"};}}return{success:false,message:"Not found."};}
function getRefundRequests(){var data=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("MASTER_ORDERS").getDataRange().getValues(),out=[];for(var i=1;i<data.length;i++){if(!data[i][MO_RECORD])continue;var c=String(data[i][MO_COMPLAINT]||"");if(c.indexOf("REFUND_REQUEST")!==0)continue;var reason="",bankName="",bankAccount="";var jsonPart=c.replace("REFUND_REQUEST:","").replace("REFUND_REQUEST: ","");try{var obj=JSON.parse(jsonPart);reason=obj.reason||"";bankName=obj.bank||"";bankAccount=obj.account||"";}catch(e){reason=jsonPart;}var nm=String(data[i][MO_NOTES]||"");var pmMatch=nm.match(/Pay:(\w+)/);out.push({row:i+1,record:data[i][MO_RECORD],customer:data[i][MO_CUSTOMER],contact:data[i][MO_CONTACT]||"",product:data[i][MO_PRODUCT],qty:data[i][MO_QTY],status:data[i][MO_STATUS],priceIDR:data[i][MO_PRICE_IDR]||0,priceUSD:data[i][MO_PRICE_USD]||0,paymentMethod:pmMatch?pmMatch[1]:"",bankName:bankName,bankAccount:bankAccount,reason:reason,time:data[i][MO_TIME]?data[i][MO_TIME].toString():""});}out.reverse();return out;}
function approveRefund(record){var ss=SpreadsheetApp.getActiveSpreadsheet();var sheet=ss.getSheetByName("MASTER_ORDERS"),data=sheet.getDataRange().getValues();for(var i=1;i<data.length;i++){if(data[i][MO_RECORD]===record&&String(data[i][MO_COMPLAINT]).indexOf("REFUND_REQUEST")===0){sheet.getRange(i+1,MO_STATUS+1).setValue("Cancelled");sheet.getRange(i+1,MO_COMPLAINT+1).setValue("REFUND");sheet.getRange(i+1,MO_UPDATED+1).setValue(new Date());var prod=data[i][MO_PRODUCT];var qName=prod==="Heart Instant"?"InstantQueue":prod==="Heart Special"?"SpecialQueue":"RegulerQueue";var qSheet=ss.getSheetByName(qName);var qData=qSheet.getDataRange().getValues();for(var j=qData.length-1;j>=1;j--){if(qData[j][0]===record){qSheet.deleteRow(j+1);break;}}logDelivery(record,"Admin","Refund",0,"Refund approved");return{success:true,message:"Refund approved: "+record};}}return{success:false,message:"Not found."};}
