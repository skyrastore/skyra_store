function checkReturningCustomer(contact,customerName){var ss=SpreadsheetApp.getActiveSpreadsheet();var sheets=["MASTER_ORDERS","Archive_Orders"];var co=String(contact||"").trim(),cu=String(customerName||"").toLowerCase().trim();var count=0;for(var s=0;s<sheets.length;s++){var sh=ss.getSheetByName(sheets[s]);if(!sh)continue;var data=sh.getDataRange().getValues();for(var i=1;i<data.length;i++){if(data[i][MO_STATUS]==="Completed"||data[i][MO_STATUS]==="Running"||(data[i][MO_SOURCE]==="Migrated"&&data[i][MO_STATUS]==="Running")){if((co&&String(data[i][MO_CONTACT])===co)||(cu&&String(data[i][MO_CUSTOMER]).toLowerCase()===cu))count++;}}}var tier="New",discount=0;if(count>=11){tier="Gold";discount=7.5}else if(count>=6){tier="Silver";discount=5}else if(count>=1){tier="Bronze";discount=2.5}return{isReturning:count>=1,tier:tier,discount:discount,orderCount:count};}
