function setWorkerStatus(name,status,note){var valid=["Running","Banwave","Update","Holiday"];if(valid.indexOf(status)===-1)return{success:false,message:"Invalid."};var ss=SpreadsheetApp.getActiveSpreadsheet(),sheet=ss.getSheetByName("Settings");function setVal(k,v){var d=sheet.getDataRange().getValues();for(var i=1;i<d.length;i++){if(d[i][0]===k){sheet.getRange(i+1,2).setValue(v);return;}}sheet.appendRow([k,v,"",new Date()]);}setVal("Worker "+name+" Status",status);if(note)setVal("Worker "+name+" Note",note);ss.getSheetByName("DeliveryLogs_MASTER").appendRow([new Date(),"SYSTEM","Worker Status",name,"System",0,status+(note?" - "+note:""),""]);invalidateSettingsCache();return{success:true,status:status,message:name+": "+status};}
function getWorkerPausedDays(worker,fromDate,toDate){var logs=SpreadsheetApp.getActiveSpreadsheet().getSheetByName("DeliveryLogs_MASTER").getDataRange().getValues();var events=[];for(var i=1;i<logs.length;i++){if(logs[i][DL_RECORD]!=="SYSTEM"||String(logs[i][DL_PRODUCT])!=="Worker Status"||logs[i][DL_WORKER]!==worker)continue;var t=logs[i][DL_TIME];if(!t)continue;events.push({time:new Date(t),status:String(logs[i][DL_STATUS]).split(" - ")[0].trim()});}events.sort(function(a,b){return a.time-b.time;});var initStatus="Running";for(var i=0;i<events.length;i++){if(events[i].time<=fromDate)initStatus=events[i].status;else break;}var pausedMs=0,lastPause=initStatus!=="Running"?fromDate:null;for(var i=0;i<events.length;i++){var e=events[i];if(e.time<=fromDate)continue;if(e.time>toDate)break;if(e.status!=="Running"&&!lastPause)lastPause=e.time;if(e.status==="Running"&&lastPause){pausedMs+=(Math.min(e.time,toDate)-lastPause);lastPause=null;}}if(lastPause)pausedMs+=(toDate-lastPause);return Math.round(pausedMs/864e5);}
