function addToBlacklist(contact){if(!contact)return{success:false};var ss=SpreadsheetApp.getActiveSpreadsheet(),sheet=ss.getSheetByName("Settings"),data=sheet.getDataRange().getValues();for(var i=1;i<data.length;i++){if(data[i][0]==="Blacklist"){var cur=String(data[i][1]||"");var list=cur?cur.split(",").map(function(s){return s.trim()}).filter(String):[];if(list.indexOf(contact)>=0)return{success:false,message:"Already blacklisted."};list.push(contact);sheet.getRange(i+1,2).setValue(list.join(","));invalidateSettingsCache();return{success:true,message:contact+" blacklisted."};}}sheet.appendRow(["Blacklist",contact,"",new Date()]);invalidateSettingsCache();return{success:true,message:contact+" blacklisted."};}
function removeFromBlacklist(contact){if(!contact)return{success:false};var ss=SpreadsheetApp.getActiveSpreadsheet(),sheet=ss.getSheetByName("Settings"),data=sheet.getDataRange().getValues();for(var i=1;i<data.length;i++){if(data[i][0]==="Blacklist"){var list=String(data[i][1]||"").split(",").map(function(s){return s.trim()}).filter(function(s){return s&&s!==contact});sheet.getRange(i+1,2).setValue(list.join(","));invalidateSettingsCache();return{success:true,message:contact+" removed."};}}return{success:false,message:"Not found."};}
